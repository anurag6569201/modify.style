# ── Django ──
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True

# ── Script generation (LLM) ──
# Which provider to use for narration scripts: azure_openai | gemini
AI_SCRIPT_PROVIDER=gemini
GOOGLE_GEMINI_API_KEY=

# ── Azure OpenAI (preferred script provider) ──
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure Speech (neural TTS + caption timings) ──
AZURE_SPEECH_KEY=
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_REGION=

# ── Azure Translator (localization) ──
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_REGION=

# ── Azure Blob Storage + CDN (media + share playback) ──
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=demoforge-media
AZURE_CDN_BASE_URL=
