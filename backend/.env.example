# ── Django ──
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True

# Local dev uses SQLite when DATABASE_URL is unset.
# Production (Azure): set DATABASE_URL to PostgreSQL connection string.
# URL-encode special characters in the password (e.g. @ → %40).
# DATABASE_URL=postgres://user:pass%40word@host:5432/demoforge?sslmode=require

# Comma-separated origins allowed to call the API (include your Vercel URL in prod)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# CSRF_TRUSTED_ORIGINS=https://demoforge-api.azurewebsites.net,https://your-app.vercel.app

# Production only:
# ALLOWED_HOSTS=demoforge-api.azurewebsites.net

# ── Script generation (LLM) ──
# azure_openai | gemini
AI_SCRIPT_PROVIDER=gemini
GOOGLE_GEMINI_API_KEY=

# ── Azure OpenAI ──
AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure Speech (neural TTS + caption timings) ──
AZURE_SPEECH_KEY=
AZURE_SPEECH_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_SPEECH_REGION=eastus2

# ── Azure Translator (localization) ──
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_REGION=eastus2

# ── Azure Blob Storage + CDN (required in production) ──
# Local dev: leave unset to use backend/media/ on disk.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=demoforge-media
AZURE_CDN_BASE_URL=
