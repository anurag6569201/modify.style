# Inherits root .gitignore — keep frontend-specific ignores here
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules/
dist/
dist-ssr/
.vite/
.vercel/

# Env (never commit — use .env.example as template)
.env
.env.*
!.env.example
*.local

vite.config.ts.timestamp-*.mjs

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
