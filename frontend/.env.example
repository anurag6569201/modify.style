# Backend API base URL
# Local:  http://localhost:8000
# Prod:   https://demoforge-api.azurewebsites.net
VITE_API_URL=http://localhost:8000

# Google OAuth client ID (public — safe in frontend, restrict by origin in Google Console)
VITE_GOOGLE_CLIENT_ID=

# Optional: Greaby API fallback (voice panel uses backend Azure Speech by default)
VITE_GREABY_API_URL=
VITE_GREABY_API_KEY=
