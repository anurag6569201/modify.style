*.py[cod]
*$py.class
venv/
.venv/
env/
*.sqlite3
db.sqlite3
backend/db.sqlite3
backend/media/
*.log
htmlcov/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Azure CLI local defaults (may reference subscription/resource names)
backend/.azure/

